POSTGRES_USER=milkfarm
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=milk_farm

JWT_SECRET=change-me-to-at-least-32-characters-long-random-string
SECURE_COOKIES=true
CORS_ORIGINS=https://milkfarm.example.com

ORIGIN=https://milkfarm.example.com

RUST_LOG=info,milk_farm_backend=debug
LOG_FORMAT=text
TRUST_PROXY=false

# JWT token TTL (seconds)
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=604800

# Database pool size
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2

# Rate limiting: max requests per window
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECS=60

# Graceful shutdown timeout (seconds)
SHUTDOWN_TIMEOUT_SECS=30

# Lely Integration
LELY_ENABLED=false
LELY_BASE_URL=https://farmauth.lely.com
LELY_USERNAME=
LELY_PASSWORD=
LELY_FARM_KEY=
LELY_SYNC_INTERVAL_SECS=300
LELY_ENCRYPTION_KEY=change-me-to-at-least-32-characters-random-key
