%% ========== LEVEL 2: Container ==========

flowchart TB
    Browser["Браузер"]

    subgraph Docker["Docker Compose"]
        direction TB

        Nginx["Nginx\nreverse proxy\nSSL termination\n:80 → :443"]

        Frontend["Frontend\nSvelteKit 5 + SSR\nNode.js 20\n:3000"]

        Backend["Backend\nRust / Axum 0.8\nREST API\n:3000"]

        Postgres[("PostgreSQL 16\n25+ таблиц\n:5432")]
    end

    LelyAPI[("Lely Cloud\nfarmauth.lely.com")]
    GHCR[("GHCR\nDocker Registry")]

    Browser -->|"HTTPS"| Nginx
    Nginx -->|"/*"| Frontend
    Nginx -->|"/api/*"| Backend
    Frontend -->|"SSR fetch /api"| Backend
    Backend -->|"sqlx PgPool\n2-20 conn"| Postgres
    Backend -.->|"reqwest HTTPS\nsync"| LelyAPI
    GHCR -.->|"CI/CD"| Frontend
    GHCR -.->|"CI/CD"| Backend

    style Browser fill:#757575,stroke:#424242,color:#fff
    style Nginx fill:#00838f,stroke:#006064,color:#fff
    style Frontend fill:#2e7d32,stroke:#1b5e20,color:#fff
    style Backend fill:#c62828,stroke:#b71c1c,color:#fff
    style Postgres fill:#1565c0,stroke:#0d47a1,color:#fff
    style LelyAPI fill:#6a1b9a,stroke:#4a148c,color:#fff
    style GHCR fill:#546e7a,stroke:#37474f,color:#fff
    style Docker fill:#fafafa,stroke:#bdbdbd,color:#333

