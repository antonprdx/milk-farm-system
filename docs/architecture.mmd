%% ========== DEPLOYMENT ==========

flowchart TB
    subgraph Deploy["Deployment Diagram (Production)"]
        direction TB

        Internet(("Internet"))

        subgraph Server["Сервер (Docker Compose)"]
            direction TB

            NginxD["nginx:alpine\n:80 → :443\nSSL termination\nrate limiting"]

            subgraph AppContainers["Application Containers"]
                direction LR
                FrontendD["ghcr.io/.../frontend\nSvelteKit Node.js\n:3000\n256MB limit"]
                BackendD["ghcr.io/.../backend\nRust binary\n:3000\n256MB limit"]
            end

            PostgresD["postgres:16\n:5432\n512MB limit\nvolume: pgdata"]
        end

        LelyExt(("Lely Cloud\nAPI"))
        GHCRExt(("GHCR\nRegistry"))

        Internet -->|"HTTPS :443"| NginxD
        NginxD -->|"/*"| FrontendD
        NginxD -->|"/api/*"| BackendD
        BackendD -->|"sqlx"| PostgresD
        BackendD -.->|"sync"| LelyExt
        GHCRExt -.->|"docker pull"| AppContainers
    end

