%% ========== LEVEL 1: System Context ==========

flowchart LR
    subgraph L1["System Context"]
        direction LR

        Farmer[" Фермер "]
        AdminUsr[" Администратор фермы "]
        LelyCloud[(" Lely Cloud API роботизированные системы доения ")]

        subgraph System["Milk Farm System"]
            App[" Веб-приложение управления молочной фермой "]
        end

        Farmer -->|"просмотр отчётов и данных"| App
        AdminUsr -->|"управление поголовьем, настройка"| App
        LelyCloud -.->|"синхронизация данных каждые 5 мин"| App
    end

    style Farmer fill:#2e7d32,stroke:#1b5e20,color:#fff
    style AdminUsr fill:#1565c0,stroke:#0d47a1,color:#fff
    style LelyCloud fill:#6a1b9a,stroke:#4a148c,color:#fff
    style System fill:#f5f5f5,stroke:#424242,color:#333
    style App fill:#fff,stroke:#424242,color:#333

%% ========== LEVEL 2: Container ==========

flowchart TB
    subgraph L2["Container Diagram"]
        direction TB

        Browser[" Браузер "]

        subgraph Docker["Docker Compose"]
            direction TB

            Nginx[" Nginx reverse proxy SSL termination :80 :443 "]

            Frontend[" Frontend SvelteKit + SSR Node.js :3000 "]

            Backend[" Backend Rust / Axum 0.8 REST API :3000 "]

            Postgres[(" PostgreSQL 16 25+ таблиц :5432 ")]
        end

        LelyAPI[(" Lely Cloud API farmauth.lely.com ")]

        Browser -->|"HTTPS"| Nginx
        Nginx -->|"/*"| Frontend
        Nginx -->|"/api/*"| Backend
        Frontend -->|"SSR fetch /api"| Backend
        Backend -->|"sqlx PgPool"| Postgres
        Backend -.->|"reqwest HTTPS синхронизация"| LelyAPI

        GHCR[("GHCR Docker Registry")]
        GHCR -.->|"CI/CD GitHub Actions"| Backend
        GHCR -.->|"CI/CD GitHub Actions"| Frontend
    end

    style Browser fill:#757575,stroke:#424242,color:#fff
    style Nginx fill:#00838f,stroke:#006064,color:#fff
    style Frontend fill:#2e7d32,stroke:#1b5e20,color:#fff
    style Backend fill:#c62828,stroke:#b71c1c,color:#fff
    style Postgres fill:#1565c0,stroke:#0d47a1,color:#fff
    style LelyAPI fill:#6a1b9a,stroke:#4a148c,color:#fff
    style GHCR fill:#546e7a,stroke:#37474f,color:#fff
    style Docker fill:#fafafa,stroke:#bdbdbd,color:#333

%% ========== LEVEL 3: Backend Components ==========

flowchart TB
    subgraph L3["Backend — Components"]
        direction TB

        Client[" HTTP Client (Browser / SSR) "]

        subgraph MW["Middleware Stack"]
            direction TB
            Trace["Tracing"]
            Compress["Gzip Compression"]
            CORS["CORS"]
            RateLimit["Rate Limit 100/60s"]
            ReqId["Request ID"]
            Metrics["Prometheus Metrics"]
        end

        subgraph API["REST API /api/v1"]
            direction TB
            AuthAPI["Auth login · register logout · refresh"]
            AnimalAPI["Animals CRUD · timeline"]
            ReproAPI["Reproduction осеменение · стельность отёл · охота · сухостой"]
            MilkAPI["Milk надои · визиты качество · танк"]
            FeedAPI["Feed рационы · визиты типы · группы"]
            ReportAPI["Reports сводные · специализированные экспорт CSV/PDF"]
            AnalyticsAPI["Analytics KPI · тренды оповещения · прогнозы"]
            SettingsAPI["Settings пользователи · JWT алерты · бэкап"]
            LelyAPI["Lely конфиг · статус синхронизация"]
        end

        subgraph Services["Service Layer"]
            direction TB
            AuthSvc["JWT + bcrypt HttpOnly cookies"]
            DBSvc["Business Logic 14 сервисов"]
            LelySvc["Lely Integration client · mapper sync · crypto"]
        end

        subgraph Data["Data Layer"]
            direction LR
            PgPool["sqlx PgPool 2–20 connections"]
        end

        subgraph External["External"]
            Lely["Lely Cloud"]
            PG[("PostgreSQL")]
        end

        Client -->|"HTTP"| MW
        MW --> API
        API --> Services
        Services --> Data
        Data --> PgPool
        PgPool --> PG
        LelySvc -.-> Lely
    end

    style Client fill:#757575,stroke:#424242,color:#fff
    style MW fill:#e0f7fa,stroke:#00838f,color:#006064
    style API fill:#fff3e0,stroke:#e65100,color:#bf360c
    style Services fill:#e8f5e9,stroke:#2e7d32,color:#1b5e20
    style Data fill:#e3f2fd,stroke:#1565c0,color:#0d47a1
    style PgPool fill:#1565c0,stroke:#0d47a1,color:#fff
    style External fill:#fafafa,stroke:#bdbdbd,color:#333
    style Lely fill:#6a1b9a,stroke:#4a148c,color:#fff
    style PG fill:#1565c0,stroke:#0d47a1,color:#fff

