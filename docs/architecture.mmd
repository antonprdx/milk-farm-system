%% ========== DEPLOYMENT ==========

flowchart TB
    subgraph Deploy["Deployment Diagram (Production)"]
        direction TB

        Internet(("Internet"))

        subgraph Server["Сервер (Docker Compose)"]
            direction TB

            NginxD["nginx:alpine :80 → :443 SSL termination rate limiting"]

            subgraph AppContainers["Application Containers"]
                direction LR
                FrontendD["ghcr.io/.../frontend SvelteKit Node.js :3000 256MB limit"]
                BackendD["ghcr.io/.../backend Rust binary :3000 256MB limit"]
            end

            PostgresD["postgres:16 :5432 512MB limit volume: pgdata"]
        end

        LelyExt(("Lely Cloud API"))
        GHCRExt(("GHCR Registry"))

        Internet -->|"HTTPS :443"| NginxD
        NginxD -->|"/*"| FrontendD
        NginxD -->|"/api/*"| BackendD
        BackendD -->|"sqlx"| PostgresD
        BackendD -.->|"sync"| LelyExt
        GHCRExt -.->|"docker pull"| AppContainers
    end

