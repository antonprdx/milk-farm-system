            ML["Analytics-ML\nFastAPI · XGBoost\n:8001"]
        end

        subgraph Stores["Хранилища"]
            direction LR
            Postgres[("TimescaleDB Pg16\n25+ таблиц :5432")]
            Redis[("Redis 7\ncache + rate limit\n:6379")]
        end

        MLflow["MLflow — experiment tracking :5000"]
    end

    LelyAPI[("Lely Cloud")]
    GHCR[("GHCR Registry")]

    Browser -->|"HTTPS"| Nginx
    Nginx -->|"/*"| Frontend
    Nginx -->|"/api/*"| Backend
