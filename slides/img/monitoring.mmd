flowchart TB
    subgraph Apps["Приложения"]
        direction LR
        Backend["Backend\n/metrics (Prometheus)\nOTel traces"]
        Frontend["Frontend\nлоги stdout"]
        ML["Analytics-ML\nOTel traces + логи"]
    end

    subgraph Collect["Сбор данных"]
        direction LR
        Prom["Prometheus :9090\nscrape /metrics\nretention 30d"]
        Promtail["Promtail\nчтение Docker logs"]
    end

    subgraph Storage["Хранение"]
        direction LR
        Tempo["Tempo :4317\nOTLP gRPC traces"]
        Loki["Loki :3100\nlog aggregation"]
    end

    Grafana["Grafana :3001\nдашборды\nUnified datasource"]

    Apps -->|"метрики"| Prom
    Apps -->|"traces OTLP"| Tempo
    Apps -->|"stdout логи"| Promtail
    Promtail -->|"push"| Loki

    Prom --> Grafana
    Tempo --> Grafana
    Loki --> Grafana

