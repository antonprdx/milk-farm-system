flowchart LR
    Farmer["Фермер\nпросмотр отчётов,\nданных о животных"]
    Admin["Администратор\nуправление поголовьем,\nнастройки, пользователи"]
    LelyCloud[("Lely Cloud API\nроботизированные\nсистемы доения")]
