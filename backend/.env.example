DATABASE_URL=postgres://milkfarm:milkfarm@localhost:5432/milkfarm

# IMPORTANT: Change JWT_SECRET in production! Must be at least 32 characters.
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars

# JWT token TTL (seconds). Defaults: access=900 (15m), refresh=604800 (7d)
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=604800

# Database pool size. Defaults: max=20, min=2
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2

# IMPORTANT: Change LELY_ENCRYPTION_KEY in production! Must be at least 32 characters.
# Used for AES-GCM encryption of stored Lely API credentials.
LELY_ENCRYPTION_KEY=change_this_to_a_random_key_at_least_32_chars

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
HOST=0.0.0.0
PORT=3000
SECURE_COOKIES=false
TRUST_PROXY=false
RUST_LOG=milk_farm_backend=debug,tower_http=debug

# Log format: "text" (default) or "json"
LOG_FORMAT=text

# Rate limiting: max requests per window. Defaults: 100/60s
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECS=60

# Graceful shutdown timeout (seconds). Default: 30
SHUTDOWN_TIMEOUT_SECS=30

# Lely Integration
LELY_ENABLED=false
LELY_BASE_URL=https://farmauth.lely.com
LELY_USERNAME=
LELY_PASSWORD=
LELY_FARM_KEY=
LELY_SYNC_INTERVAL_SECS=300
